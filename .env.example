# ── ArenaCrypto — Variables de entorno requeridas ──────────────────────────
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local a git.

# Supabase (ArenaCrypto DB)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # Settings > API > service_role (solo servidor)

# WalletConnect / Reown
NEXT_PUBLIC_WALLETCONNECT_ID=           # cloud.reown.com → Create Project

# Polygon — Escrow wallet que recibe los depósitos USDC
NEXT_PUBLIC_ESCROW_ADDRESS=0x...

# Gemini AI (árbitro de evidencias)
GEMINI_API_KEY=                         # aistudio.google.com/app/apikey

# ── Bridge: Proyecto-Torneos (solo lectura) ─────────────────────────────────
NEXT_PUBLIC_PT_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_PT_SUPABASE_ANON_KEY=sb_publishable_...
